# Production Environment Variables for Frontend
# Used when npm run build is executed

# API URL — Do NOT set this when deploying on Vercel!
# Vercel rewrites in vercel.json proxy /api and /uploads to Render backend.
# Leave unset so it defaults to /api (relative path → Vercel rewrites handle it).
# VITE_API_URL=

# Enable production mode
VITE_ENV=production
