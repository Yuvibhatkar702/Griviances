# Frontend Environment Variables for Vercel

# DO NOT set VITE_API_URL on Vercel!
# vercel.json rewrites proxy /api/* and /uploads/* to the Render backend.
# Leaving this unset makes API calls use /api (relative) which Vercel rewrites handle.
# VITE_API_URL=

# OPTIONAL - AI Service URL (if frontend calls it directly)
# VITE_AI_API_URL=https://your-ai.onrender.com

# OPTIONAL - Google Maps API Key (if using)
# VITE_GOOGLE_MAPS_API_KEY=your-google-maps-api-key
